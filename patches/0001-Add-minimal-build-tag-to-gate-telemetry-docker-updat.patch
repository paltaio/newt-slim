+//go:build minimal
+
+package telemetry
+
+import (
+	"context"
+	"net/http"
+	"time"
+
+	"go.opentelemetry.io/otel/attribute"
+	"go.opentelemetry.io/otel/metric"
+)
+
+// Config is a no-op placeholder for the minimal build.
+type Config struct {
+	ServiceName          string
+	ServiceVersion       string
+	SiteID               string
+	Region               string
+	PromEnabled          bool
+	OTLPEnabled          bool
+	OTLPEndpoint         string
+	OTLPInsecure         bool
+	MetricExportInterval time.Duration
+	AdminAddr            string
+	BuildVersion         string
+	BuildCommit          string
+}
+
+// Setup is a no-op placeholder for the minimal build.
+type Setup struct {
+	PrometheusHandler http.Handler
+}
+
+// StateView mirrors the full-build interface so callers compile unchanged.
+type StateView interface {
+	ListSites() []string
+	Online(siteID string) (online bool, ok bool)
+	LastHeartbeat(siteID string) (t time.Time, ok bool)
+	ActiveSessions(siteID string) (n int64, ok bool)
+}
+
+func FromEnv() Config                                    { return Config{} }
+func Init(context.Context, Config) (*Setup, error)       { return &Setup{}, nil }
+func (s *Setup) Shutdown(context.Context) error          { return nil }
+func WrapHTTPHandler(h http.Handler, _ string) http.Handler { return h }
+
+func UpdateSiteInfo(string, string)                  {}
+func RegisterStateView(StateView)                    {}
+func RegisterBuildInfo(string, string)               {}
+func SetObservableCallback(func(context.Context, metric.Observer) error)      {}
+func SetProxyObservableCallback(func(context.Context, metric.Observer) error) {}
+
+func SiteLabelKVs() []attribute.KeyValue { return nil }
+func ShouldIncludeTunnelID() bool        { return false }
+func ShouldIncludeSiteLabels() bool      { return false }
+
+func IncConfigReload(context.Context, string)                                  {}
+func IncSiteRegistration(context.Context, string)                              {}
+func AddTunnelBytes(context.Context, string, string, int64)                    {}
+func AddTunnelBytesSet(context.Context, int64, attribute.Set)                  {}
+func ObserveWSConnectLatency(context.Context, float64, string, string)         {}
+func IncWSMessage(context.Context, string, string)                             {}
+func IncWSDisconnect(context.Context, string, string)                          {}
+func IncWSKeepaliveFailure(context.Context, string)                            {}
+func SetWSConnectionState(bool)                                                {}
+func IncWSReconnect(context.Context, string)                                   {}
+func ObserveWSSessionDuration(context.Context, float64, string)                {}
+func ObserveProxyActiveConnsObs(metric.Observer, int64, []attribute.KeyValue)  {}
+func ObserveProxyBufferBytesObs(metric.Observer, int64, []attribute.KeyValue)  {}
+func ObserveProxyAsyncBacklogObs(metric.Observer, int64, []attribute.KeyValue) {}
+func IncProxyDrops(context.Context, string, string)                            {}
+func IncProxyAccept(context.Context, string, string, string, string)           {}
+func ObserveProxyConnectionDuration(context.Context, string, string, string, float64) {
+}
+func IncProxyConnectionEvent(context.Context, string, string, string) {}
+func ObserveConfigApply(context.Context, string, string, float64)     {}
+func IncCertRotation(context.Context, string)                         {}
+func ObserveTunnelLatency(context.Context, string, string, float64)   {}
+func IncReconnect(context.Context, string, string, string)            {}
+func IncConnAttempt(context.Context, string, string)                  {}
+func IncConnError(context.Context, string, string)                    {}
