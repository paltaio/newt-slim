+//go:build minimal
+
+package docker
+
+import "errors"
+
+type Container struct {
+	ID       string             `json:"id"`
+	Name     string             `json:"name"`
+	Image    string             `json:"image"`
+	State    string             `json:"state"`
+	Status   string             `json:"status"`
+	Ports    []Port             `json:"ports"`
+	Labels   map[string]string  `json:"labels"`
+	Created  int64              `json:"created"`
+	Networks map[string]Network `json:"networks"`
+	Hostname string             `json:"hostname"`
+}
+
+type Port struct {
+	PrivatePort int    `json:"privatePort"`
+	PublicPort  int    `json:"publicPort,omitempty"`
+	Type        string `json:"type"`
+	IP          string `json:"ip,omitempty"`
+}
+
+type Network struct {
+	NetworkID           string   `json:"networkId"`
+	EndpointID          string   `json:"endpointId"`
+	Gateway             string   `json:"gateway,omitempty"`
+	IPAddress           string   `json:"ipAddress,omitempty"`
+	IPPrefixLen         int      `json:"ipPrefixLen,omitempty"`
+	IPv6Gateway         string   `json:"ipv6Gateway,omitempty"`
+	GlobalIPv6Address   string   `json:"globalIPv6Address,omitempty"`
+	GlobalIPv6PrefixLen int      `json:"globalIPv6PrefixLen,omitempty"`
+	MacAddress          string   `json:"macAddress,omitempty"`
+	Aliases             []string `json:"aliases,omitempty"`
+	DNSNames            []string `json:"dnsNames,omitempty"`
+}
+
+type EventCallback func(containers []Container)
+
+type EventMonitor struct{}
+
+func CheckSocket(string) bool { return false }
+
+func IsWithinHostNetwork(string, string, int) (bool, error) {
+	return false, errors.New("docker support disabled")
+}
+
+func ListContainers(string, bool) ([]Container, error) {
+	return nil, errors.New("docker support disabled")
+}
+
+func NewEventMonitor(string, bool, EventCallback) (*EventMonitor, error) {
+	return nil, errors.New("docker support disabled")
+}
+
+func (*EventMonitor) Start() error { return errors.New("docker support disabled") }
+func (*EventMonitor) Stop()        {}
